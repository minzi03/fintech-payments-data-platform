{
    "name": "${DEBEZIUM_CONNECTOR_NAME}",
    "config": {
        "connector.class": "io.debezium.connector.postgresql.PostgresConnector",
        "tasks.max": "1",
        "database.hostname": "${DEBEZIUM_DATABASE_HOST}",
        "database.port": "${DEBEZIUM_DATABASE_PORT}",
        "database.user": "${DEBEZIUM_DATABASE_USER}",
        "database.password": "${DEBEZIUM_DATABASE_PASSWORD}",
        "database.dbname": "${DEBEZIUM_DATABASE_NAME}",
        "topic.prefix": "${KAFKA_TOPIC_PREFIX}",
        "plugin.name": "pgoutput",
        "slot.name": "${DEBEZIUM_SLOT_NAME}",
        "slot.drop.on.stop": "false",
        "publication.name": "${DEBEZIUM_PUBLICATION_NAME}",
        "publication.autocreate.mode": "disabled",
        "schema.include.list": "payments",
        "table.include.list": "payments.customers,payments.accounts,payments.merchants,payments.payment_transactions,payments.transaction_events,payments.refunds",
        "snapshot.mode": "${DEBEZIUM_SNAPSHOT_MODE}",
        "decimal.handling.mode": "precise",
        "time.precision.mode": "microseconds",
        "tombstones.on.delete": "true",
        "provide.transaction.metadata": "true",
        "heartbeat.interval.ms": "${DEBEZIUM_HEARTBEAT_INTERVAL_MS}",
        "include.schema.changes": "true",
        "key.converter": "org.apache.kafka.connect.json.JsonConverter",
        "key.converter.schemas.enable": "true",
        "value.converter": "org.apache.kafka.connect.json.JsonConverter",
        "value.converter.schemas.enable": "true",
        "topic.creation.default.replication.factor": "1",
        "topic.creation.default.partitions": "${KAFKA_DEFAULT_PARTITIONS}",
        "topic.creation.default.cleanup.policy": "delete",
        "topic.creation.default.retention.ms": "${KAFKA_RETENTION_MS}"
    }
}
