# Application
APP_ENV=local
LOG_LEVEL=INFO

# PostgreSQL - local-only placeholders; replace in an untracked .env file
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=fintech_payments
POSTGRES_USER=payments_app
POSTGRES_PASSWORD=change_me
DATABASE_URL=postgresql://payments_app:change_me@localhost:5432/fintech_payments

# Deterministic generator defaults
GENERATOR_SEED=42
GENERATOR_CUSTOMERS=10
GENERATOR_MERCHANTS=5
GENERATOR_TRANSACTIONS=50
GENERATOR_INVALID_RATE=0.0
GENERATOR_DUPLICATE_RATE=0.0

# Phase 2 local settlement batch paths (runtime data remains untracked)
SETTLEMENT_INBOUND_DIR=data/inbound/settlements
SETTLEMENT_BRONZE_DIR=data/bronze/settlements
SETTLEMENT_QUARANTINE_DIR=data/quarantine/settlements
SETTLEMENT_MANIFEST_DB=data/control/settlement_manifest.sqlite3
SETTLEMENT_FIXTURE_SEED=42

# Kafka and Schema Registry
# Planned only; no Kafka service exists in Phase 2.
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
SCHEMA_REGISTRY_URL=http://localhost:8081

# MinIO - secret values intentionally blank
# Planned only; no MinIO service exists in Phase 2.
MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=
MINIO_SECRET_KEY=
MINIO_BRONZE_BUCKET=bronze

# Airflow
# Planned only; no Airflow service exists in Phase 2.
AIRFLOW_UID=50000

# Snowflake and dbt - secret values intentionally blank
# Planned only; no Snowflake integration exists in Phase 2.
SNOWFLAKE_ACCOUNT=
SNOWFLAKE_USER=
SNOWFLAKE_PASSWORD=
SNOWFLAKE_ROLE=DATA_ENGINEER
SNOWFLAKE_WAREHOUSE=COMPUTE_WH
SNOWFLAKE_DATABASE=FINTECH_PAYMENTS
SNOWFLAKE_SCHEMA=RAW
DBT_THREADS=4
