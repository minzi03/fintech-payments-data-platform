# Application
APP_ENV=local
LOG_LEVEL=INFO

# PostgreSQL - local-only placeholders; replace in an untracked .env file
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=fintech_payments
POSTGRES_USER=payments_app
POSTGRES_PASSWORD=change_me
DATABASE_URL=postgresql://payments_app:change_me@localhost:5432/fintech_payments
POSTGRES_MAX_REPLICATION_SLOTS=10
POSTGRES_MAX_WAL_SENDERS=10

# PostgreSQL CDC - local-only connector role placeholders
DEBEZIUM_CONNECTOR_NAME=payments-postgres-cdc
DEBEZIUM_SLOT_NAME=fintech_payments_cdc_slot
DEBEZIUM_PUBLICATION_NAME=fintech_payments_cdc_publication
DEBEZIUM_DATABASE_HOST=postgres
DEBEZIUM_DATABASE_PORT=5432
DEBEZIUM_DATABASE_NAME=fintech_payments
DEBEZIUM_DATABASE_USER=payments_cdc
DEBEZIUM_DATABASE_PASSWORD=change_me_cdc
DEBEZIUM_HEARTBEAT_INTERVAL_MS=10000
DEBEZIUM_SNAPSHOT_MODE=initial

# Deterministic generator defaults
GENERATOR_SEED=42
GENERATOR_CUSTOMERS=10
GENERATOR_MERCHANTS=5
GENERATOR_TRANSACTIONS=50
GENERATOR_INVALID_RATE=0.0
GENERATOR_DUPLICATE_RATE=0.0

# Settlement batch paths (runtime data remains untracked)
SETTLEMENT_INBOUND_DIR=data/inbound/settlements
SETTLEMENT_BRONZE_DIR=data/bronze
SETTLEMENT_QUARANTINE_DIR=data/quarantine
SETTLEMENT_MANIFEST_DB=data/control/settlement_manifest.sqlite3
SETTLEMENT_FIXTURE_SEED=42
SETTLEMENT_PARTNER_ID=VCB
STORAGE_BACKEND=local

# Kafka and Kafka Connect - local-only settings
KAFKA_CLUSTER_ID=MkU3OEVBNTcwNTJENDM2Qk
KAFKA_BOOTSTRAP_SERVERS=localhost:29092
KAFKA_EXTERNAL_PORT=29092
KAFKA_CONNECT_PORT=8083
KAFKA_CONNECT_URL=http://localhost:8083
KAFKA_TOPIC_PREFIX=fintech.cdc
KAFKA_DEFAULT_PARTITIONS=3
KAFKA_RETENTION_MS=604800000
CDC_HTTP_TIMEOUT_SECONDS=10
CDC_HTTP_MAX_ATTEMPTS=10

# Reliable Kafka CDC consumer -> immutable Bronze Parquet
CDC_CONSUMER_GROUP_ID=fintech-cdc-bronze-v1
CDC_CONSUMER_CLIENT_ID=fintech-cdc-bronze-consumer
CDC_CONSUMER_TOPICS=fintech.cdc.payments.customers,fintech.cdc.payments.accounts,fintech.cdc.payments.merchants,fintech.cdc.payments.payment_transactions,fintech.cdc.payments.transaction_events,fintech.cdc.payments.refunds
CDC_CONSUMER_AUTO_OFFSET_RESET=earliest
CDC_CONSUMER_BATCH_SIZE=100
CDC_CONSUMER_FLUSH_INTERVAL_SECONDS=5
CDC_CONSUMER_POLL_TIMEOUT_MS=1000
CDC_CONSUMER_MAX_POLL_INTERVAL_MS=300000
CDC_CONSUMER_SESSION_TIMEOUT_MS=45000
CDC_CONSUMER_HEARTBEAT_INTERVAL_MS=15000
CDC_CONSUMER_MAX_RETRIES=3
CDC_CONSUMER_RETRY_BACKOFF_SECONDS=0.5
CDC_DLQ_TOPIC=fintech.cdc.dlq
CDC_BRONZE_BUCKET=fintech-bronze
CDC_QUARANTINE_BUCKET=fintech-quarantine
CDC_SCHEMA_VERSION=cdc-bronze-v1
CDC_CONSUMER_MANIFEST_DB=data/control/cdc_consumer_manifest.sqlite3
CDC_CONSUMER_TEMP_DIR=data/tmp/cdc_consumer
CDC_CONSUMER_SHUTDOWN_TIMEOUT_SECONDS=30

# MinIO - local-only placeholders; replace in an untracked .env file
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=change_me_minio_access
MINIO_SECRET_KEY=change_me_minio_secret
MINIO_SECURE=false
MINIO_REGION=us-east-1
MINIO_BRONZE_BUCKET=fintech-bronze
MINIO_QUARANTINE_BUCKET=fintech-quarantine
MINIO_SILVER_BUCKET=fintech-silver
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_CONNECT_TIMEOUT_SECONDS=5
MINIO_READ_TIMEOUT_SECONDS=30
MINIO_MAX_RETRIES=3

# Bronze-to-Silver processing (local or MinIO, no orchestration service)
SILVER_LOCAL_ROOT=data/silver
SILVER_MANIFEST_DB=data/control/silver_manifest.sqlite3
SILVER_TEMP_DIR=data/tmp/silver
SILVER_CODE_VERSION=phase6-v1
SILVER_SCHEMA_VERSION=silver-v1
SILVER_SUPPORTED_CDC_SCHEMA=cdc-bronze-v1
SILVER_SETTLEMENT_CONTRACT=contracts/batch/settlement_v1.yml
SILVER_MAX_OBJECTS=100

# Airflow 3.3 local orchestration - replace all secret placeholders in untracked .env
AIRFLOW_IMAGE_NAME=fintech-payments-airflow:3.3.0
AIRFLOW_UID=50000
AIRFLOW_WEB_PORT=8080
AIRFLOW_EXECUTOR=LocalExecutor
AIRFLOW_DATABASE_USER=airflow_metadata
AIRFLOW_DATABASE_PASSWORD=change_me_airflow_database
AIRFLOW_DATABASE_NAME=airflow_metadata
CONTROL_DATABASE_USER=pipeline_control
CONTROL_DATABASE_PASSWORD=change_me_control_database
AIRFLOW_FERNET_KEY=replace_with_generated_urlsafe_base64_fernet_key
AIRFLOW_SECRET_KEY=replace_with_generated_random_jwt_secret
AIRFLOW_ADMIN_USER=platform-admin
AIRFLOW_TIMEZONE=UTC
AIRFLOW_SETTLEMENT_SCHEDULE="0 1 * * *"
AIRFLOW_CDC_HEALTH_SCHEDULE="*/5 * * * *"
AIRFLOW_SILVER_SCHEDULE="*/15 * * * *"
AIRFLOW_TASK_RETRIES=2
AIRFLOW_RETRY_DELAY_SECONDS=60
AIRFLOW_TASK_TIMEOUT_SECONDS=1800

# Orchestration quality gates and CDC health targets
SETTLEMENT_REJECTION_WARN_RATE=0.01
SETTLEMENT_REJECTION_FAIL_RATE=0.05
SILVER_REJECTION_WARN_RATE=0.01
SILVER_REJECTION_FAIL_RATE=0.05
CDC_LAG_WARN_THRESHOLD=1000
CDC_LAG_FAIL_THRESHOLD=10000
CDC_FRESHNESS_WARN_SECONDS=120
CDC_FRESHNESS_FAIL_SECONDS=600

# Snowflake and dbt - secret values intentionally blank
# Planned only; no Snowflake integration exists in Phase 7.
SNOWFLAKE_ACCOUNT=
SNOWFLAKE_USER=
SNOWFLAKE_PASSWORD=
SNOWFLAKE_ROLE=DATA_ENGINEER
SNOWFLAKE_WAREHOUSE=COMPUTE_WH
SNOWFLAKE_DATABASE=FINTECH_PAYMENTS
SNOWFLAKE_SCHEMA=RAW
DBT_THREADS=4
