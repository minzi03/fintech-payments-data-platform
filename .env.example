# Application
APP_ENV=local
LOG_LEVEL=INFO

# PostgreSQL - local-only placeholders; replace in an untracked .env file
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=fintech_payments
POSTGRES_USER=payments_app
POSTGRES_PASSWORD=change_me
DATABASE_URL=postgresql://payments_app:change_me@localhost:5432/fintech_payments

# Deterministic generator defaults
GENERATOR_SEED=42
GENERATOR_CUSTOMERS=10
GENERATOR_MERCHANTS=5
GENERATOR_TRANSACTIONS=50
GENERATOR_INVALID_RATE=0.0
GENERATOR_DUPLICATE_RATE=0.0

# Settlement batch paths (runtime data remains untracked)
SETTLEMENT_INBOUND_DIR=data/inbound/settlements
SETTLEMENT_BRONZE_DIR=data/bronze
SETTLEMENT_QUARANTINE_DIR=data/quarantine
SETTLEMENT_MANIFEST_DB=data/control/settlement_manifest.sqlite3
SETTLEMENT_FIXTURE_SEED=42
STORAGE_BACKEND=local

# Kafka and Schema Registry
# Planned only; no Kafka service exists in Phase 3.
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
SCHEMA_REGISTRY_URL=http://localhost:8081

# MinIO - local-only placeholders; replace in an untracked .env file
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=change_me_minio_access
MINIO_SECRET_KEY=change_me_minio_secret
MINIO_SECURE=false
MINIO_REGION=us-east-1
MINIO_BRONZE_BUCKET=fintech-bronze
MINIO_QUARANTINE_BUCKET=fintech-quarantine
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_CONNECT_TIMEOUT_SECONDS=5
MINIO_READ_TIMEOUT_SECONDS=30
MINIO_MAX_RETRIES=3

# Airflow
# Planned only; no Airflow service exists in Phase 3.
AIRFLOW_UID=50000

# Snowflake and dbt - secret values intentionally blank
# Planned only; no Snowflake integration exists in Phase 3.
SNOWFLAKE_ACCOUNT=
SNOWFLAKE_USER=
SNOWFLAKE_PASSWORD=
SNOWFLAKE_ROLE=DATA_ENGINEER
SNOWFLAKE_WAREHOUSE=COMPUTE_WH
SNOWFLAKE_DATABASE=FINTECH_PAYMENTS
SNOWFLAKE_SCHEMA=RAW
DBT_THREADS=4
